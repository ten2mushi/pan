# Zig build artifacts
.zig-cache/
zig-out/

# Generated test vectors — regenerated on demand from committed manifests/seeds
# (brief requirement: minimize disk usage). Manifests and generate.py ARE committed.
/tests/vectors/**/*.bin
/tests/vectors/**/*.raw
/tests/vectors/**/*.pcm
/tests/vectors/**/*.npy

# --- data/ ---------------------------------------------------------------
# Only the Integraation and Pachelbel example inputs are committed (their decoded
# *_lpcm.wav + metadata); every other input source is kept local. Source media
# containers (.webm etc.) stay ignored even in the kept dirs — large and redundant
# with the decoded LPCM.
/data/input/*
!/data/input/Integraation/
!/data/input/Pachelbel Canon in D Major - the original and best version./
/data/input/**/*.mkv
/data/input/**/*.webm
/data/input/**/*.mp4
/data/input/**/*.m4a
/data/input/**/*.opus
/data/input/**/*.part
# Intermediates (decoded mono LPCM, feature matrices) — regenerated on demand.
/data/work/
# Generated renders — large and regenerable; kept entirely local. The README's demo
# videos live on YouTube, so nothing under data/output is committed.
/data/output/

# Example kept local (not tracked).
/examples/extract_and_generate/

# Project docs / specs kept local (not tracked).
/specifications/
/notes/
/research/
/dev-notes/
/archive/
/CLAUDE.md
/CONTRIBUTING.md

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
*.swp

# Local Claude Code agent state (session locks, not project content)
.claude/
