# Zig build artifacts
.zig-cache/
zig-out/

# Generated test vectors — regenerated on demand from committed manifests/seeds
# (brief requirement: minimize disk usage). Manifests and generate.py ARE committed.
/tests/vectors/**/*.bin
/tests/vectors/**/*.raw
/tests/vectors/**/*.pcm
/tests/vectors/**/*.npy

# Local audio test inputs (large binary media). Not committed — the brief's
# disk-minimal requirement; supply your own clips under data/input/.
/data/

# Python
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
*.swp
